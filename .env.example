# -----------------------------
# LLM models and inference
# -----------------------------
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=tinyllama
OLLAMA_EMBED_MODEL=nomic-embed-text

# -----------------------------
# Core service connection URLs
# -----------------------------
REDIS_URL=redis://redis:6379/0
POSTGRES_URL=postgresql://llmops:llmops@postgres:5432/llmops

# -----------------------------
# PostgreSQL bootstrap credentials (compose service)
# -----------------------------
POSTGRES_DB=llmops
POSTGRES_USER=llmops
POSTGRES_PASSWORD=llmops

# -----------------------------
# API security and traffic control
# -----------------------------
API_KEY=replace-with-a-strong-api-key
RATE_LIMIT_PER_MINUTE=20

# -----------------------------
# Caching and performance tuning
# -----------------------------
CACHE_TTL_SECONDS=3600
CACHE_PREFIX=llm:prompt
SLOW_REQUEST_SECONDS=1.0
WORKER_METRICS_PORT=8001

# -----------------------------
# RAG retrieval and chunking behavior
# -----------------------------
RAG_TOP_K=3
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150

# -----------------------------
# Public ports (host side)
# -----------------------------
FRONTEND_PORT=80
OLLAMA_PORT=11434
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# -----------------------------
# Observability and Grafana auth
# -----------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-password
